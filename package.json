{
  "name": "beybstation",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@11.1.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=11"
  },
  "scripts": {
    "dev": "sst dev",
    "deploy": "sst deploy",
    "typecheck": "pnpm -r typecheck",
    "dev:api": "pnpm --filter @beybstation/api dev",
    "dev:web": "pnpm --filter @beybstation/web dev"
  },
  "workspaces": [
    "packages/*"
  ]
}
